# Backend
DATABASE_URL=sqlite:///./fraud_ledger.db
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Model paths (relative to project root)
ENSEMBLE_PATH=backend/fraud_ensemble.pkl
CATEGORY_MAP_PATH=backend/category_map.json
FRAUD_CENTROID_PATH=backend/fraud_centroid.npy

# Threshold defaults (overridable at runtime via API)
ALLOW_THRESHOLD=0.35
BLOCK_THRESHOLD=0.70
VELOCITY_LIMIT=3
VELOCITY_WINDOW_SECONDS=10
# Model version
ENSEMBLE_VERSION=1.0.0

